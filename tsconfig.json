{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@/*": ["src/frontend/*", "src/backend/*"],
      "@backend/*": ["src/backend/*"],
      "@frontend/*": ["src/frontend/*"],
      "~/*": ["*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "worker-configuration.d.ts"]
}
