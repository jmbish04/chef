{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "worker-configuration.d.ts",
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@/*": ["src/frontend/*", "src/backend/*"],
      "@backend/*": ["src/backend/*"],
      "@frontend/*": ["src/frontend/*"],
      "~/*": ["*"]
    }
  },
  "include": [
    ".astro/types.d.ts", 
    "src/**/*", 
    "worker-configuration.d.ts"
  ]
}
