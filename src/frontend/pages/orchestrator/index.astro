---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ChatInterface from '@/components/orchestrator/ChatInterface';
---
<BaseLayout title="Kitchen Orchestrator">
  <div class="max-w-4xl mx-auto w-full h-full space-y-4">
    <div class="flex flex-col gap-2">
      <h2 class="text-2xl font-bold tracking-tight">Kitchen Orchestrator</h2>
      <p class="text-muted-foreground">Ask me to translate recipes to appliance specific instructions, or ingest a manual.</p>
    </div>

    <ChatInterface client:load />
  </div>
</BaseLayout>
